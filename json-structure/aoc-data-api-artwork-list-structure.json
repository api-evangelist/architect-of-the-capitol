{
  "$schema": "https://json-structure.org/meta/extended/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/architect-of-the-capitol/refs/heads/main/json-structure/aoc-data-api-artwork-list-structure.json",
  "title": "ArtworkList",
  "type": "object",
  "properties": {
    "total": {
      "type": "integer"
    },
    "offset": {
      "type": "integer"
    },
    "limit": {
      "type": "integer"
    },
    "artworks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {},
          "title": {},
          "artist": {},
          "yearCreated": {},
          "medium": {},
          "dimensions": {},
          "location": {},
          "buildingId": {},
          "description": {},
          "imageUrl": {},
          "acquisitionDate": {},
          "historicalSignificance": {}
        }
      }
    }
  }
}